enum Status {
  applied
  interview
  offer
  rejected
  withdrawn
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  createdAt      DateTime        @default(now())
  companies      Company[]
  resumes        Resume[]
  applications   Application[]
  importedEmails ImportedEmail[]
}

model Company {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  ownerId      String?
  owner        User?         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  applications Application[]

  @@unique([ownerId, name])
}

model Resume {
  id           String        @id @default(cuid())
  name         String
  fileUrl      String
  createdAt    DateTime      @default(now())
  ownerId      String?
  owner        User?         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  applications Application[]
}

model Application {
  id          String   @id @default(cuid())
  company     String
  role        String
  status      Status   @default(applied)
  source      String?
  dateApplied DateTime
  notes       String?
  gmailId     String?
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  companyId   String?
  companyRef  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  resumeId    String?
  resume      Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@unique([ownerId, gmailId])
}

model ImportedEmail {
  id        String   @id @default(cuid())
  gmailId   String
  subject   String
  from      String
  snippet   String
  company   String?
  role      String?
  source    String?
  status    Status?
  score     Int
  reviewed  Boolean  @default(false)
  ownerId   String?
  owner     User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([ownerId, gmailId])
}
