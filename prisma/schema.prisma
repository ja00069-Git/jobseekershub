enum Status {
  wishlist
  applied
  interview
  offer
  rejected
  withdrawn
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Resume {
  id           String        @id @default(cuid())
  name         String
  fileUrl      String
  createdAt    DateTime      @default(now())
  applications Application[]
}

model Application {
  id          String   @id @default(cuid())
  company     String
  role        String
  status      Status   @default(applied)
  source      String?
  dateApplied DateTime
  notes       String?
  gmailId     String?  @unique
  companyId   String?
  companyRef  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  resumeId    String?
  resume      Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

model ImportedEmail {
  id        String   @id @default(cuid())
  gmailId   String   @unique
  subject   String
  from      String
  snippet   String
  company   String?
  role      String?
  source    String?
  status    Status?
  score     Int
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now())
}