enum Status {
  wishlist
  applied
  phone
  interview
  offer
  rejected
  withdrawn
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id          String   @id @default(cuid())
  company     String
  role        String
  status      Status   @default(applied)
  location    String?
  salary      Int?
  dateApplied DateTime
  notes       String?
  createdAt   DateTime @default(now())
}